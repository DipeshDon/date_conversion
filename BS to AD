    .btn.blue:hover { box-shadow:0 8px 24px rgba(49,130,206,0.4); }
    .error-msg { color:#fc8181; font-size:0.82rem; text-align:center; margin-top:12px; display:none; }
    .error-msg.show { display:block; }
    .result-box { margin-top:26px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.12); border-radius:20px; padding:28px 24px; display:none; }
    .result-box.show { display:block; animation:fadeUp 0.3s ease; }
    .result-main { text-align:center; margin-bottom:20px; }
    .result-label { color:rgba(255,255,255,0.45); font-size:0.73rem; text-transform:uppercase; letter-spacing:1px; margin-bottom:10px; }
    .result-year { color:#fff; font-size:2.4rem; font-weight:900; letter-spacing:-1px; line-height:1; }
    .result-month-day { color:rgba(255,255,255,0.85); font-size:1.1rem; font-weight:600; margin-top:4px; }
    .result-weekday { color:#68d391; font-size:0.9rem; margin-top:6px; font-weight:600; }
    .tithi-wrap { margin-top:14px; }
    .tithi-badge { display:inline-flex; align-items:center; gap:10px; background:rgba(237,137,54,0.15); border:1px solid rgba(237,137,54,0.35); border-radius:12px; padding:10px 18px; }
    .tithi-moon { font-size:1.5rem; line-height:1; }
    .tithi-info { text-align:left; }
    .tithi-name { color:#fbd38d; font-size:1rem; font-weight:700; }
    .tithi-sub  { color:rgba(255,255,255,0.45); font-size:0.72rem; margin-top:2px; }
    .result-meta { padding-top:18px; border-top:1px solid rgba(255,255,255,0.08); display:flex; justify-content:center; flex-wrap:wrap; }
    .meta-item { text-align:center; padding:0 14px; border-right:1px solid rgba(255,255,255,0.08); }
    .meta-item:last-child { border-right:none; }
    .meta-val { color:#63b3ed; font-size:0.9rem; font-weight:700; }
