    }
    .today-badge:hover { background:rgba(99,179,237,0.22); }
    .btn { width:100%; padding:15px; border:none; border-radius:14px; color:#fff; font-size:1rem; font-weight:800; cursor:pointer; letter-spacing:0.4px; transition:transform 0.15s,box-shadow 0.15s; }
    .btn:hover { transform:translateY(-2px); }
    .btn:active { transform:translateY(0); }
    .btn.red  { background:linear-gradient(135deg,#e53e3e,#c53030); }
    .btn.blue { background:linear-gradient(135deg,#3182ce,#2b6cb0); }
