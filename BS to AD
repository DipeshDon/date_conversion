      display:flex; align-items:center; justify-content:center;
      padding:20px; overflow-x:hidden;
    }
    .page { display:none; width:100%; max-width:540px; animation:fadeUp 0.4s ease; }
    .page.active { display:block; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:translateY(0)} }
    .card {
      background:rgba(255,255,255,0.06); backdrop-filter:blur(24px);
      border:1px solid rgba(255,255,255,0.12); border-radius:28px;
      padding:44px 40px; box-shadow:0 40px 80px rgba(0,0,0,0.5);
    }
    .header { text-align:center; margin-bottom:36px; }
    .flag { font-size:52px; display:block; margin-bottom:12px; }
    h1 { color:#fff; font-size:1.7rem; font-weight:800; letter-spacing:-0.5px; }
    .subtitle { color:rgba(255,255,255,0.45); font-size:0.88rem; margin-top:7px; }
    .choice-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
    .choice-card {
      cursor:pointer; background:rgba(255,255,255,0.05);
      border:2px solid rgba(255,255,255,0.1); border-radius:20px;
      padding:30px 16px; text-align:center; transition:all 0.25s; user-select:none;
    }
    .choice-card:hover { transform:translateY(-5px); }
    .choice-card.bs-to-ad:hover { border-color:#e53e3e; box-shadow:0 12px 32px rgba(229,62,62,0.25); background:rgba(229,62,62,0.08); }
    .choice-card.ad-to-bs:hover { border-color:#4299e1; box-shadow:0 12px 32px rgba(66,153,225,0.25); background:rgba(66,153,225,0.08); }
    .choice-icon { font-size:42px; display:block; margin-bottom:12px; }
    .choice-title { color:#fff; font-size:1.05rem; font-weight:700; margin-bottom:5px; }
    .choice-sub { color:rgba(255,255,255,0.4); font-size:0.75rem; line-height:1.5; }
    .arrow-badge { display:inline-flex; align-items:center; justify-content:center; border-radius:20px; padding:5px 12px; font-size:0.75rem; margin-top:10px; font-weight:600; }
    .bs-to-ad .arrow-badge { background:rgba(229,62,62,0.15); color:#fc8181; }
    .ad-to-bs .arrow-badge { background:rgba(66,153,225,0.15); color:#63b3ed; }
    .back-btn {
      display:inline-flex; align-items:center; gap:6px;
      background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.12);
      color:rgba(255,255,255,0.6); border-radius:20px; padding:7px 16px;
      font-size:0.8rem; cursor:pointer; margin-bottom:22px; transition:all 0.2s; user-select:none;
    }
    .back-btn:hover { background:rgba(255,255,255,0.14); color:#fff; }
    .mode-pill { display:inline-flex; align-items:center; gap:6px; padding:5px 14px; border-radius:20px; font-size:0.78rem; font-weight:700; margin-bottom:14px; letter-spacing:0.3px; }
    .mode-pill.bs { background:rgba(229,62,62,0.2); color:#fc8181; border:1px solid rgba(229,62,62,0.3); }
    .mode-pill.ad { background:rgba(66,153,225,0.2); color:#63b3ed; border:1px solid rgba(66,153,225,0.3); }
    label { display:block; color:rgba(255,255,255,0.6); font-size:0.76rem; font-weight:700; letter-spacing:0.6px; text-transform:uppercase; margin-bottom:8px; }
    .input-row { display:grid; grid-template-columns:2fr 2fr 1.5fr; gap:10px; margin-bottom:20px; }
    .sub-label { text-align:center; color:rgba(255,255,255,0.28); font-size:0.67rem; margin-top:5px; }
    input[type="number"], select {
      width:100%; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.12);
      border-radius:12px; color:#fff; font-size:0.95rem; padding:13px; outline:none;
      transition:border-color 0.2s,background 0.2s; appearance:none; -webkit-appearance:none;
    }
