    input[type="number"]::placeholder { color:rgba(255,255,255,0.22); }
    select option { background:#16213e; color:#fff; }
    .today-badge {
      display:inline-flex; align-items:center; gap:6px;
      background:rgba(99,179,237,0.12); border:1px solid rgba(99,179,237,0.25);
      color:#63b3ed; font-size:0.78rem; padding:6px 14px; border-radius:20px;
