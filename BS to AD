  [31,32,31,32,31,30,30,30,29,29,30,31], // 2087
  [31,31,31,32,31,31,30,29,30,29,30,30], // 2088
  [31,31,32,31,31,31,30,29,30,29,30,30], // 2089
  [31,31,32,32,31,30,30,29,30,29,30,30], // 2090
];

const BS_MONTHS    = ['Baisakh','Jestha','Ashadh','Shrawan','Bhadra','Ashwin','Kartik','Mangsir','Poush','Magh','Falgun','Chaitra'];
const BS_MONTHS_NP = ['बैशाख','जेठ','असार','श्रावण','भाद्र','आश्विन','कार्तिक','मंसिर','पुष','माघ','फाल्गुन','चैत्र'];
const AD_MONTHS    = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const WEEK_DAYS    = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const SEASONS      = ['','Spring','Spring','Summer','Summer','Monsoon','Monsoon','Autumn','Autumn','Winter','Winter','Spring','Spring'];
const TITHI_EN     = ['Pratipada','Dwitiya','Tritiya','Chaturthi','Panchami','Shashthi','Saptami','Ashtami','Navami','Dashami','Ekadashi','Dwadashi','Trayodashi','Chaturdashi'];
const TITHI_NP     = ['प्रतिपदा','द्वितीया','तृतीया','चतुर्थी','पञ्चमी','षष्ठी','सप्तमी','अष्टमी','नवमी','दशमी','एकादशी','द्वादशी','त्रयोदशी','चतुर्दशी'];

// Tithi reference — verified: Nepal Mar 4 2026 (= 2082/11/20 BS) = Krishna Pratipada
const SYNODIC = 29.53059;
const NM_REF  = 20501.234705; // new moon ~Feb 17.23, 2026 UTC

// ═══════════════════════════════════════════════════════
//  CORE FUNCTIONS
//  REF: BS 2000/01/01 = AD 1943/04/14 (verified against 26 Nepal NY dates)
// ═══════════════════════════════════════════════════════
function utcDay(y, m, d) { return Date.UTC(y, m-1, d) / 86400000; }
const REF = utcDay(1943, 4, 14);

function bsToAdUTC(bsY, bsM, bsD) {
  const i = bsY - 2000;
  if (i < 0 || i >= D.length) return null;
  if (bsD < 1 || bsD > D[i][bsM-1]) return null;
  let days = 0;
  for (let k = 0; k < i; k++) days += D[k].reduce((a,b)=>a+b,0);
  for (let m = 0; m < bsM-1; m++) days += D[i][m];
  return REF + days + bsD - 1;
}

function adToBS(adY, adM, adD) {
  let rem = utcDay(adY, adM, adD) - REF;
  if (rem < 0) return null;
  let yi = 0, m = 0, d = 1;
  while (rem > 0) {
    if (yi >= D.length) return null;
    const yr = D[yi].reduce((a,b)=>a+b,0);
    if (rem >= yr) { rem -= yr; yi++; continue; }
    for (let i = 0; i < 12; i++) {
      if (rem < D[yi][i]) { m = i; d = rem + 1; rem = 0; break; }
      rem -= D[yi][i];
    }
  }
  return { year: 2000+yi, month: m+1, day: d };
}

function getTithi(utcDayInt) {
  // Use Nepal local time (GMT+5:45) for tithi
  const nepalFrac = utcDayInt + (5*60+45)/(24*60);
  const daysSince = ((nepalFrac - NM_REF) % SYNODIC + SYNODIC) % SYNODIC;
  const tithiNum  = Math.floor(daysSince / (SYNODIC/30));
  const isKrishna = tithiNum >= 15;
  const idx = isKrishna ? tithiNum - 15 : tithiNum;
  let nameEn = idx < 14 ? TITHI_EN[idx] : (isKrishna ? 'Amavasya' : 'Purnima');
  let nameNp = idx < 14 ? TITHI_NP[idx] : (isKrishna ? 'औंसी' : 'पूर्णिमा');
  const paksha = isKrishna ? 'Krishna Paksha (कृष्ण पक्ष)' : 'Shukla Paksha (शुक्ल पक्ष)';
  // Moon emoji: waxing for Shukla, waning for Krishna
  let moon;
  if      (tithiNum === 0)                   moon = '🌑';
  else if (tithiNum < 4)                     moon = '🌒';
  else if (tithiNum < 8)                     moon = '🌓';
  else if (tithiNum < 12)                    moon = '🌔';
  else if (tithiNum === 14||tithiNum === 15) moon = '🌕';
  else if (tithiNum < 19)                    moon = '🌖';
  else if (tithiNum < 23)                    moon = '🌗';
  else if (tithiNum < 28)                    moon = '🌘';
  else                                       moon = '🌑';
  return { nameEn, nameNp, paksha, moon };
}

// Nepal local date (GMT+5:45)
function getNepalToday() {
  const now = new Date();
  const nd  = new Date(now.getTime() + (5*60+45)*60*1000);
  return { year: nd.getUTCFullYear(), month: nd.getUTCMonth()+1, day: nd.getUTCDate() };
}

// Navigation
function goTo(mode) { document.querySelectorAll('.page').forEach(p=>p.classList.remove('active')); document.getElementById('page-'+mode).classList.add('active'); window.scrollTo(0,0); }
function goHome()   { document.querySelectorAll('.page').forEach(p=>p.classList.remove('active')); document.getElementById('page-home').classList.add('active'); window.scrollTo(0,0); }

// Fill today
function fillTodayBS() {
  const t = getNepalToday();
  const bs = adToBS(t.year, t.month, t.day);
  if (!bs) return;
  document.getElementById('bs-year').value  = bs.year;
  document.getElementById('bs-month').value = bs.month;
  document.getElementById('bs-day').value   = bs.day;
}
function fillTodayAD() {
  const t = getNepalToday();
  document.getElementById('ad-year').value  = t.year;
  document.getElementById('ad-month').value = t.month;
  document.getElementById('ad-day').value   = t.day;
}

// Convert BS → AD
function convertBsToAd() {
  const year=parseInt(document.getElementById('bs-year').value);
  const month=parseInt(document.getElementById('bs-month').value);
  const day=parseInt(document.getElementById('bs-day').value);
  const errEl=document.getElementById('err-bs'), resEl=document.getElementById('result-bs');
  errEl.classList.remove('show'); resEl.classList.remove('show');
  if (!year||!month||!day||isNaN(year)||isNaN(month)||isNaN(day)) return showErr(errEl,'⚠️ Please fill in all three fields.');
  const i=year-2000;
  if (i<0||i>=D.length) return showErr(errEl,`⚠️ Year ${year} is outside supported range (2000–2090).`);
  const maxD=D[i][month-1];
  if (day<1||day>maxD) return showErr(errEl,`⚠️ Day must be 1–${maxD} for ${BS_MONTHS[month-1]} ${year}.`);
  const adUTC=bsToAdUTC(year,month,day);
  if (adUTC===null) return showErr(errEl,'⚠️ Conversion failed.');
  const dt=new Date(adUTC*86400000);
  const adY=dt.getUTCFullYear(), adM=dt.getUTCMonth()+1, adD=dt.getUTCDate(), dow=dt.getUTCDay();
  const t=getTithi(adUTC);
  document.getElementById('r-bs-year').textContent     = adY;
  document.getElementById('r-bs-monthday').textContent = `${AD_MONTHS[adM-1]} ${adD}`;
  document.getElementById('r-bs-weekday').textContent  = `✦ ${WEEK_DAYS[dow]}`;
  document.getElementById('r-bs-moon').textContent     = t.moon;
  document.getElementById('r-bs-tithi').textContent    = `${t.nameEn} (${t.nameNp})`;
  document.getElementById('r-bs-paksha').textContent   = t.paksha;
  document.getElementById('r-bs-input').textContent    = `${year} ${BS_MONTHS[month-1]} ${day}`;
  document.getElementById('r-bs-nepmonth').textContent = BS_MONTHS_NP[month-1];
  document.getElementById('r-bs-season').textContent   = SEASONS[month];
  resEl.classList.add('show');
}

// Convert AD → BS
function convertAdToBs() {
  const year=parseInt(document.getElementById('ad-year').value);
  const month=parseInt(document.getElementById('ad-month').value);
  const day=parseInt(document.getElementById('ad-day').value);
  const errEl=document.getElementById('err-ad'), resEl=document.getElementById('result-ad');
  errEl.classList.remove('show'); resEl.classList.remove('show');
  if (!year||!month||!day||isNaN(year)||isNaN(month)||isNaN(day)) return showErr(errEl,'⚠️ Please fill in all three fields.');
  const check=new Date(Date.UTC(year,month-1,day));
  if (check.getUTCFullYear()!==year||check.getUTCMonth()!==month-1||check.getUTCDate()!==day) return showErr(errEl,`⚠️ ${AD_MONTHS[month-1]} ${day}, ${year} is not a valid date.`);
  const inputUTC=utcDay(year,month,day);
  if (inputUTC<REF) return showErr(errEl,'⚠️ Date is before supported range.');
  const bs=adToBS(year,month,day);
  if (!bs) return showErr(errEl,'⚠️ Conversion failed. Date may be out of range.');
  const dow=check.getUTCDay();
  const t=getTithi(inputUTC);
  document.getElementById('r-ad-year').textContent     = bs.year;
  document.getElementById('r-ad-monthday').textContent = `${BS_MONTHS[bs.month-1]} ${bs.day}`;
  document.getElementById('r-ad-weekday').textContent  = `✦ ${WEEK_DAYS[dow]}`;
  document.getElementById('r-ad-moon').textContent     = t.moon;
  document.getElementById('r-ad-tithi').textContent    = `${t.nameEn} (${t.nameNp})`;
  document.getElementById('r-ad-paksha').textContent   = t.paksha;
  document.getElementById('r-ad-input').textContent    = `${AD_MONTHS[month-1]} ${day}, ${year}`;
  document.getElementById('r-ad-nepmonth').textContent = BS_MONTHS_NP[bs.month-1];
  document.getElementById('r-ad-season').textContent   = SEASONS[bs.month];
  resEl.classList.add('show');
}

function showErr(el,msg){ el.textContent=msg; el.classList.add('show'); }
</script>
