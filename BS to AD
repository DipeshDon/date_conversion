</head>
<body>

<div class="page active" id="page-home">
  <div class="card">
    <div class="header">
      <span class="flag">🇳🇵</span>
      <h1>Nepali Date Converter</h1>
      <p class="subtitle">Choose a conversion direction to get started</p>
    </div>
    <div class="choice-grid">
      <div class="choice-card bs-to-ad" onclick="goTo('bs-to-ad')">
        <span class="choice-icon">📅</span>
        <div class="choice-title">BS → AD</div>
        <div class="choice-sub">Bikram Sambat<br>to Gregorian</div>
        <div class="arrow-badge">विक्रम → ईसवी</div>
      </div>
      <div class="choice-card ad-to-bs" onclick="goTo('ad-to-bs')">
        <span class="choice-icon">🗓️</span>
        <div class="choice-title">AD → BS</div>
        <div class="choice-sub">Gregorian<br>to Bikram Sambat</div>
        <div class="arrow-badge">ईसवी → विक्रम</div>
      </div>
    </div>
  </div>
</div>

<div class="page" id="page-bs-to-ad">
  <div class="card">
    <span class="back-btn" onclick="goHome()">← Back</span>
    <div class="header" style="margin-bottom:20px;">
      <div class="mode-pill bs">📅 Bikram Sambat → AD</div>
      <h1>BS to AD</h1>
      <p class="subtitle">Convert a Nepali date to English calendar</p>
    </div>
    <span class="today-badge" onclick="fillTodayBS()">📅 Fill Today's BS Date</span>
    <label>Bikram Sambat Date</label>
    <div class="input-row">
      <div><input type="number" id="bs-year" placeholder="2082" min="2000" max="2090"/><div class="sub-label">Year (साल)</div></div>
      <div>
        <select id="bs-month">
          <option value="">Month</option>
          <option value="1">Baisakh (बैशाख)</option>
          <option value="2">Jestha (जेठ)</option>
          <option value="3">Ashadh (असार)</option>
          <option value="4">Shrawan (श्रावण)</option>
          <option value="5">Bhadra (भाद्र)</option>
          <option value="6">Ashwin (आश्विन)</option>
          <option value="7">Kartik (कार्तिक)</option>
          <option value="8">Mangsir (मंसिर)</option>
          <option value="9">Poush (पुष)</option>
          <option value="10">Magh (माघ)</option>
          <option value="11">Falgun (फाल्गुन)</option>
          <option value="12">Chaitra (चैत्र)</option>
        </select>
        <div class="sub-label">Month (महिना)</div>
      </div>
      <div><input type="number" id="bs-day" placeholder="20" min="1" max="32"/><div class="sub-label">Day (दिन)</div></div>
    </div>
    <button class="btn red" onclick="convertBsToAd()">Convert to AD →</button>
    <div class="error-msg" id="err-bs"></div>
    <div class="result-box" id="result-bs">
      <div class="result-main">
        <div class="result-label">Equivalent AD Date</div>
        <div class="result-year" id="r-bs-year"></div>
        <div class="result-month-day" id="r-bs-monthday"></div>
        <div class="result-weekday" id="r-bs-weekday"></div>
        <div class="tithi-wrap"><div class="tithi-badge"><span class="tithi-moon" id="r-bs-moon"></span><div class="tithi-info"><div class="tithi-name" id="r-bs-tithi"></div><div class="tithi-sub" id="r-bs-paksha"></div></div></div></div>
      </div>
      <div class="result-meta">
        <div class="meta-item"><div class="meta-val" id="r-bs-input"></div><div class="meta-key">BS Input</div></div>
        <div class="meta-item"><div class="meta-val" id="r-bs-nepmonth"></div><div class="meta-key">Nepali Month</div></div>
        <div class="meta-item"><div class="meta-val" id="r-bs-season"></div><div class="meta-key">Season</div></div>
      </div>
    </div>
  </div>
</div>

<div class="page" id="page-ad-to-bs">
  <div class="card">
    <span class="back-btn" onclick="goHome()">← Back</span>
    <div class="header" style="margin-bottom:20px;">
      <div class="mode-pill ad">🗓️ AD → Bikram Sambat</div>
      <h1>AD to BS</h1>
      <p class="subtitle">Convert an English date to Nepali calendar</p>
    </div>
    <span class="today-badge" onclick="fillTodayAD()">📅 Fill Today's AD Date</span>
    <label>Gregorian (AD) Date</label>
    <div class="input-row">
      <div><input type="number" id="ad-year" placeholder="2026" min="1944" max="2034"/><div class="sub-label">Year</div></div>
      <div>
        <select id="ad-month">
          <option value="">Month</option>
          <option value="1">January</option><option value="2">February</option><option value="3">March</option>
          <option value="4">April</option><option value="5">May</option><option value="6">June</option>
          <option value="7">July</option><option value="8">August</option><option value="9">September</option>
          <option value="10">October</option><option value="11">November</option><option value="12">December</option>
        </select>
        <div class="sub-label">Month</div>
      </div>
      <div><input type="number" id="ad-day" placeholder="4" min="1" max="31"/><div class="sub-label">Day</div></div>
    </div>
    <button class="btn blue" onclick="convertAdToBs()">Convert to BS →</button>
    <div class="error-msg" id="err-ad"></div>
    <div class="result-box" id="result-ad">
      <div class="result-main">
        <div class="result-label">Equivalent BS Date</div>
        <div class="result-year" id="r-ad-year"></div>
        <div class="result-month-day" id="r-ad-monthday"></div>
        <div class="result-weekday" id="r-ad-weekday"></div>
        <div class="tithi-wrap"><div class="tithi-badge"><span class="tithi-moon" id="r-ad-moon"></span><div class="tithi-info"><div class="tithi-name" id="r-ad-tithi"></div><div class="tithi-sub" id="r-ad-paksha"></div></div></div></div>
      </div>
      <div class="result-meta">
        <div class="meta-item"><div class="meta-val" id="r-ad-input"></div><div class="meta-key">AD Input</div></div>
        <div class="meta-item"><div class="meta-val" id="r-ad-nepmonth"></div><div class="meta-key">Nepali Month</div></div>
        <div class="meta-item"><div class="meta-val" id="r-ad-season"></div><div class="meta-key">Season</div></div>
      </div>
    </div>
  </div>
</div>

